# kernel-pin.env — pinned references for reproducible builds.
#
# Bump KERNEL_SHA when promoting a new kernel commit to a release.
# The build pipeline (scripts/02-clone-sources.sh + .github/workflows/release.yml)
# reads this file to know exactly what to clone and verify.
#
# Why pinning: kernel-repo's `nethunter-23.2` branch is force-pushed during LOS
# upstream rebases. SHA-pinning protects against silently building against an
# unintended commit.

# Our NetHunter kernel fork (LOS lineage-23.2 + 19 commits)
KERNEL_REPO="https://github.com/ilyamen/android_kernel_nothing_sm7325_nethunter"
KERNEL_REF="nethunter-23.2"
# Bumped after adding .github/workflows/smoke-test.yml (no kernel-source change,
# but branch tip moved). Build-time KERNEL_SHA verification protects against
# silent force-pushes; if you build a different SHA, override on the command
# line: KERNEL_SHA=<sha> bash scripts/02-clone-sources.sh
KERNEL_SHA="de989ec045cf404f7dcd3a5dd819d8e6ea291f3a"

# AnyKernel3 packager (kimocoder's spacewar-tuned branch, supports Android 11-16)
ANYKERNEL_REPO="https://github.com/kimocoder/AnyKernel3"
ANYKERNEL_REF="spacewar"

# Realtek out-of-tree drivers — pinned to the upstreams that match our CFI patches
RTL8188EUS_REPO="https://github.com/aircrack-ng/rtl8188eus"
RTL88X2BU_REPO="https://github.com/morrownr/88x2bu-20210702"
RTL8821CU_REPO="https://github.com/morrownr/8821cu-20210916"

# AOSP Clang version (matches LOS spacewar-official prebuilt)
TOOLCHAIN_VERSION="r547379"
TOOLCHAIN_URL="https://android.googlesource.com/platform/prebuilts/clang/host/linux-x86/+archive/refs/heads/main-kernel/clang-${TOOLCHAIN_VERSION}.tar.gz"

# mkdtboimg.py source (kimocoder's tree — Apache 2.0, AOSP origin)
MKDTBOIMG_URL="https://raw.githubusercontent.com/kimocoder/kernel_nothing_sm7325/nethunter-15.0/scripts/mkdtboimg.py"
