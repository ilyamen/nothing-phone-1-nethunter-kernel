<?xml version="1.0" encoding="utf-8"?>
<!--
  Additional F-Droid repositories pre-configured for NetHunter users.
  F-Droid client (since v1.13) reads /system/etc/org.fdroid.fdroid/additional_repos.xml
  on first launch and adds these repos in addition to its built-in defaults.

  Each repo is 12 elements:
    name, url, sigstoreUrl, mirrors, version, timestamp, description,
    isSwap, pubKey, fingerprint, inUse, priority

  Empty <item></item> means "leave default / fetch on first refresh".
-->
<resources>
